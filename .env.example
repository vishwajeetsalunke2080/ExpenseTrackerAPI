# Database Configuration
# For async SQLAlchemy, use postgresql+asyncpg:// for PostgreSQL or sqlite+aiosqlite:// for SQLite
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database?ssl=require

# Groq Configuration (LLM Provider)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# API Configuration
API_TITLE=Expense Tracking API
API_VERSION=1.0.0
API_BASEURL=http://localhost:8000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY_PATH=private_key.pem
JWT_PUBLIC_KEY_PATH=public_key.pem

# OAuth Configuration - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# OAuth Configuration - GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/oauth/github/callback

# Email Service Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@yourapp.com
SMTP_FROM_NAME=Your App Name

# Security Configuration
BCRYPT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Rate Limiting Configuration
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
ACCOUNT_LOCK_DURATION_MINUTES=15
MAX_PASSWORD_RESET_ATTEMPTS=3
PASSWORD_RESET_WINDOW_HOURS=1
